import cv2
import matplotlib.pyplot as plt
from deepface import DeepFace
from google.colab import files

print("Upload an image with one or more faces")

# Upload image
uploaded = files.upload()
img_path = list(uploaded.keys())[0]

# Read image
img = cv2.imread(img_path)
img_rgb = cv2.cvtColor(img, cv2.COLOR_BGR2RGB)

# Analyze emotions
results = DeepFace.analyze(img_path, actions=['emotion'], enforce_detection=False)

# If only one face is detected DeepFace returns dict instead of list
if not isinstance(results, list):
    results = [results]

# Draw boxes and labels
for face in results:

    region = face["region"]
    x = region["x"]
    y = region["y"]
    w = region["w"]
    h = region["h"]

    emotion = face["dominant_emotion"]
    confidence = face["emotion"][emotion]

    # Draw rectangle
    cv2.rectangle(img_rgb, (x,y), (x+w,y+h), (0,255,0), 2)

    # Label text
    label = f"{emotion} ({confidence:.2f})"

    cv2.putText(
        img_rgb,
        label,
        (x, y-10),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.7,
        (0,255,0),
        2
    )

# Show result
plt.figure(figsize=(8,8))
plt.imshow(img_rgb)
plt.axis("off")
plt.title("Facial Expression Detection")
plt.show()
